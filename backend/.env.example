# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/transactions_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-in-production

# ── Transaction settings ──────────────────────────────────────────────────────
MAX_TRANSACTION_AMOUNT=1000000.00
WORKER_POLL_INTERVAL=1
